---
import BaseLayout from "@/layouts/base.astro";
import "@pagefind/default-ui/css/ui.css";
import { getEntry } from "astro:content";

const entry = await getEntry("views", "search");

if (!entry) {
  return Astro.redirect("/404");
}
---

<BaseLayout entry={entry}>
  <div class="container py-4">
    <div id="search"></div>
    <script type="module" src="/src/pages/search/pagefind-client.ts"></script>
  </div>
</BaseLayout>

<style is:inline>
  :root {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: oklch(var(--p));
    --pagefind-ui-text: oklch(var(--bc));
    --pagefind-ui-background: oklch(var(--b1));
    --pagefind-ui-border: oklch(var(--b2));
    --pagefind-ui-tag: oklch(var(--b2));
    --pagefind-ui-border-width: 2px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: var(--font-sans);
  }
</style>

<style is:global>
  .pagefind-ui__result.svelte-4xnkmf {
    padding: 1rem;
    margin-bottom: 0.75rem;
    border-bottom: none;
    border-radius: 8px;
    border: 1px solid var(--pagefind-ui-border);
    background-color: var(--pagefind-ui-background);
    transition: all 0.2s ease-in-out;
  }

  .pagefind-ui__result:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .pagefind-ui__search-input.svelte-e9gkc3 {
    border: 2px solid var(--pagefind-ui-border);
    padding: 0.75rem 1rem;
    font-size: 1rem;
  }

  .pagefind-ui__search-input:focus {
    border-color: var(--pagefind-ui-primary);
    box-shadow: 0 0 0 2px var(--pagefind-ui-primary) 33;
  }

  .pagefind-ui__search-clear.svelte-e9gkc3 {
    color: var(--pagefind-ui-text);
  }

  .pagefind-ui__result-title {
    font-weight: 600;
    font-size: 1.1rem;
    line-height: 1.4;
  }

  .pagefind-ui__result-excerpt {
    margin-top: 0.5rem;
    line-height: 1.6;
    color: var(--pagefind-ui-text);
  }

  .pagefind-ui__search-clear.svelte-e9gkc3 {
    padding: 0.5rem 1rem;
    border-radius: 6px;
  }

  .pagefind-ui__results {
    margin-top: 1.5rem;
  }
</style>
