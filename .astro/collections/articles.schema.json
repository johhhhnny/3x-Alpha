{
  "$ref": "#/definitions/articles",
  "definitions": {
    "articles": {
      "type": "object",
      "properties": {
        "isDraft": {
          "type": "boolean",
          "default": false
        },
        "isMainHeadline": {
          "type": "boolean",
          "default": false
        },
        "isSubHeadline": {
          "type": "boolean",
          "default": false
        },
        "cover": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "string",
              "format": "uri"
            }
          ]
        },
        "cover_alt": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "maxLength": 60,
          "errorMessage": {
            "maxLength": "Too long, max 60 characters"
          }
        },
        "description": {
          "type": "string",
          "maxLength": 160,
          "errorMessage": {
            "maxLength": "Too long, max 160 characters"
          }
        },
        "category": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "collection": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "collection"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "slug": {
                  "type": "string"
                },
                "collection": {
                  "type": "string"
                }
              },
              "required": [
                "slug",
                "collection"
              ],
              "additionalProperties": false
            }
          ]
        },
        "authors": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "collection": {
                    "type": "string"
                  }
                },
                "required": [
                  "id",
                  "collection"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "slug": {
                    "type": "string"
                  },
                  "collection": {
                    "type": "string"
                  }
                },
                "required": [
                  "slug",
                  "collection"
                ],
                "additionalProperties": false
              }
            ]
          },
          "minItems": 1
        },
        "publishedTime": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date-time"
                },
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "integer",
                  "format": "unix-time"
                }
              ]
            }
          ]
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "cover",
        "title",
        "description",
        "category",
        "authors",
        "publishedTime"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}